graph TD
    %% Subgraphs for Organization
    subgraph Genetics [Genetic & Molecular Layer]
        HOX[HOX Cluster<br/>HOXA10, HOXD11]
        COL[COL2A1<br/>Collagen Type II]
        PIEZO[PIEZO1<br/>Mechanosensor]
        CILIA[DNAH5/PKD1L1<br/>Cilia Motility]
        LBX1[LBX1<br/>Transcription Factor]
        ADGRG6[ADGRG6/GPR126<br/>Adhesion GPCR]
        PTK7[PTK7<br/>Planar Cell Polarity]
        YAP[YAP/TAZ<br/>Hippo Pathway]
        PKD2L1[PKD2L1<br/>CSF-Contacting Neurons]
        MMP[MMP1/MMP3<br/>Matrix Metalloproteinases]
        URP[Urp1/2<br/>Urotensin Peptide]
        UTS2R[UTS2R<br/>Urotensin Receptor]
        GFAP[GFAP<br/>Glial Fibrillary Acidic Protein]
    end

    subgraph Processes [Cellular & Developmental Processes]
        Region[Regionalization<br/>Segment Identity]
        ECM_Assembly[ECM Assembly<br/>Fibrillogenesis]
        Nucl_Shuttle[Nuclear Shuttling<br/>Transcriptional Switch]
        Mech_Trans[Mechanotransduction<br/>Ca2+ Influx]
        Sym_Break[Symmetry Breaking<br/>Nodal Flow]
        CSF_Sensing[CSF Flow Sensing<br/>Reissner Fiber Signal]
        Neur_Diff[Somatosensory<br/>Differentiation]
        Muscle_Diff[Myogenic Differentiation<br/>Fiber Type Specification]
        Disc_Maint[Disc Maintenance<br/>Annulus Fibrosis Fusion]
        PCP_Sig[PCP Signaling<br/>Wnt Pathway]
        Degradation[ECM Degradation<br/>Collagen Breakdown]
        Inflammation[Reactive Astrogliosis<br/>SCO Dysfunction]
    end

    subgraph Tissue [Tissue Mechanics & Properties]
        Rest_Kappa[Rest Curvature κ0<br/>Target Geometry]
        Stiffness[Stiffness EI<br/>Material Quality]
        Gain[Feedback Gain G_mech<br/>Adaptive Growth]
        Torsion[Chiral Torsion ε<br/>Initial Twist]
        Muscle_Tone[Proprioception &<br/>Muscle Tone Balance]
        Anisotropy[Tissue Anisotropy<br/>Directional Order]
    end

    subgraph Outcome [Macroscopic Outcome]
        S_Curve[S-Shaped Spine<br/>Counter-Curvature]
        Stability[Mechanical Stability<br/>Buckling Resistance]
        Scoliosis[Scoliosis<br/>System Failure]
    end

    %% Connections
    HOX --> Region
    Region --> Rest_Kappa
    Rest_Kappa --> S_Curve

    COL --> ECM_Assembly
    ECM_Assembly --> Stiffness
    Stiffness --> Stability

    PIEZO --> Mech_Trans
    Mech_Trans --> Gain
    Gain --> S_Curve

    CILIA --> Sym_Break
    Sym_Break --> Torsion
    Torsion --> S_Curve

    LBX1 --> Neur_Diff
    LBX1 --> Muscle_Diff
    Neur_Diff --> Muscle_Tone
    Muscle_Diff --> Muscle_Tone
    Muscle_Tone --> Stability

    %% NEW ARC: ADGRG6
    ADGRG6 --> Disc_Maint
    Disc_Maint --> Stiffness

    %% NEW ARC: PTK7
    PTK7 --> PCP_Sig
    PCP_Sig --> Anisotropy
    Anisotropy --> Stability

    %% NEW ARC: YAP/TAZ
    YAP --> Nucl_Shuttle
    Nucl_Shuttle --> ECM_Assembly
    Mech_Trans --> Nucl_Shuttle

    %% NEW ARC: CSF/Reissner Fiber
    CILIA --> CSF_Sensing
    PKD2L1 --> CSF_Sensing
    CSF_Sensing --> URP
    URP --> UTS2R
    UTS2R --> Muscle_Tone

    %% NEW ARC: MMP Degradation
    MMP --> Degradation
    Degradation --> Stiffness

    %% NEW ARC: Neuro-Inflammation (Djebar et al 2024)
    CILIA --> Inflammation
    GFAP -.-> Inflammation
    Inflammation -- "Disrupts RF" --> CSF_Sensing

    %% Cross-Talk and Failures
    Stability --> S_Curve
    S_Curve -- "Loss of Control" --> Scoliosis
    Stiffness -- "Too Low" --> Scoliosis
    Gain -- "Too Low" --> Scoliosis
    Torsion -- "Randomized" --> Scoliosis
    Muscle_Tone -- "Asymmetry" --> Scoliosis

    %% Styling
    classDef gene fill:#f9f,stroke:#333,stroke-width:2px;
    classDef process fill:#bbf,stroke:#333,stroke-width:2px;
    classDef tissue fill:#efe,stroke:#333,stroke-width:2px;
    classDef outcome fill:#ffd,stroke:#333,stroke-width:4px;

    class HOX,COL,PIEZO,CILIA,LBX1,ADGRG6,PTK7,YAP,PKD2L1,MMP,URP,UTS2R,GFAP gene;
    class Region,ECM_Assembly,Mech_Trans,Sym_Break,Neur_Diff,Muscle_Diff,Disc_Maint,PCP_Sig,Nucl_Shuttle,CSF_Sensing,Degradation,Inflammation process;
    class Rest_Kappa,Stiffness,Gain,Torsion,Muscle_Tone,Anisotropy tissue;
    class S_Curve,Stability,Scoliosis outcome;
